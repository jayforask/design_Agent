# DesignX Bot — Ortam Değişkenleri
# Bu dosyayı kopyalayıp ".env" olarak kaydet ve değerleri doldur.

# ─── Telegram ───────────────────────────────────────────────────────────────
# @BotFather'dan aldığın bot token
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bota erişebilecek Telegram kullanıcı ID'leri (virgülle ayır)
# Boş bırakırsan herkes kullanabilir
# ID öğrenmek için @userinfobot'a /start yaz
ALLOWED_USER_IDS=123456789,987654321

# ─── Google Gemini ───────────────────────────────────────────────────────────
# https://aistudio.google.com/app/apikey adresinden al
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Kullanılacak Gemini modeli (varsayılan: gemini-1.5-flash — ücretsiz kota)
# Seçenekler: gemini-1.5-flash | gemini-1.5-pro | gemini-2.0-flash-exp
GEMINI_MODEL=gemini-1.5-flash

# ─── Bannerbear ──────────────────────────────────────────────────────────────
# https://app.bannerbear.com/projects → API Keys
BANNERBEAR_API_KEY=bb_pr_XXXXXXXXXXXXXXXXXXXXXXXX

# Varsayılan şablon UID'si (isteğe bağlı — /sablonlar komutuyla listelenebilir)
BANNERBEAR_DEFAULT_TEMPLATE=
